recon/
reports/
config.json
*.burp
*.json.bak

# API keys and tokens
.env
secrets.txt
api_keys.txt

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# macOS
.DS_Store
.AppleDouble

