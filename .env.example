# ══════════════════════════════════════════════════════════════════════════════
#  HunterAI — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env && nano .env
# ══════════════════════════════════════════════════════════════════════════════

# ─── HackerOne (Required for report submission) ────────────────────────────
# Get from: https://hackerone.com/settings/api_token
H1_API_TOKEN=""
H1_API_USERNAME=""

# ─── Notifications (Recommended) ───────────────────────────────────────────
# TELEGRAM_BOT_TOKEN: Talk to @BotFather on Telegram → /newbot
# TELEGRAM_CHAT_ID: Talk to @userinfobot to get your chat ID
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── Recon & OSINT (Recommended) ───────────────────────────────────────────
# GITHUB_TOKEN: https://github.com/settings/tokens → Generate new token (classic)
#   Scopes needed: none (public repos only)
GITHUB_TOKEN=""

# SHODAN_API_KEY: https://account.shodan.io → API Key
#   Free tier works. InternetDB endpoints work without a key.
SHODAN_API_KEY=""

# NVD_API_KEY: https://nvd.nist.gov/developers/request-an-api-key
#   Free. Increases rate limit from 5 to 50 req/30s.
NVD_API_KEY=""

# ─── Blind Callbacks (Recommended) ─────────────────────────────────────────
# Run: interactsh-client  (or use Burp Collaborator URL)
# This is used for blind SSRF, blind XSS, and XXE detection.
INTERACTSH_URL=""

# ─── Burp Suite MCP (Optional) ─────────────────────────────────────────────
# Only needed if using Burp Suite MCP integration.
# Start Burp with: java -jar burpsuite_pro.jar --rest-api
BURP_API_URL="http://127.0.0.1:1337"
BURP_API_KEY=""

# ─── Auth Testing (Optional — set per target) ──────────────────────────────
# These are used by auth_manager.py for authenticated endpoint testing.
# Set these when testing a specific target that requires auth.
HUNT_AUTH_TOKEN=""
HUNT_COOKIES=""

# ─── Zendesk IDOR Testing (Optional — set per target) ─────────────────────
# Only needed when testing Zendesk-based targets.
ZENDESK_SUBDOMAIN=""
ZENDESK_EMAIL=""
ZENDESK_API_TOKEN=""
